# DeepSeek API Key (required)
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token signing secret (required, min 32 chars)
# Generate with: openssl rand -hex 32
TOKEN_SECRET=your-token-secret-at-least-32-chars-long

# Admin API key (required for admin panel)
# Generate with: openssl rand -hex 16
ADMIN_API_KEY=your-admin-api-key-here

# Optional: Force watermark off for all users (e.g., in development/staging)
# FORCE_WATERMARK=off

# 独角数卡发卡网购买链接（升级 Pro 跳转地址）
# 配置后，升级弹窗将显示跳转到发卡网的按钮
NEXT_PUBLIC_FAKA_URL=https://your-faka-site.com/buy/pro

# 独角数卡回调签名密钥（用于验证回调请求的合法性）
# 实际接入时配置，与独角数卡后台的 API 密钥保持一致
FAKA_CALLBACK_SECRET=your-faka-callback-secret-key

# Cloudflare Worker 发卡系统地址（零成本自动发卡方案）
# 部署 Worker 后获得的地址，如：https://issue-englisher-faka.xxx.workers.dev
NEXT_PUBLIC_FAKA_WORKER_URL=https://your-worker-url.workers.dev
