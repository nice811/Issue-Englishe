# DeepSeek API Key (required)
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token signing secret (required, min 32 chars)
# Generate with: openssl rand -hex 32
TOKEN_SECRET=your-token-secret-at-least-32-chars-long

# Admin API key (required for admin panel)
# Generate with: openssl rand -hex 16
ADMIN_API_KEY=your-admin-api-key-here

# Optional: Force watermark off for all users (e.g., in development/staging)
# FORCE_WATERMARK=off
